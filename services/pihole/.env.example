# Pi-hole environment variables
# Copy this file to .env and fill in your values before running docker compose up.

# Web admin interface password (required)
PIHOLE_PASSWORD=your_secure_password_here

# Tailscale IP address of this server (used to bind DNS/HTTP ports to the VPN interface only).
# Run `tailscale ip -4` on the server to find your Tailscale IP.
TAILSCALE_IP=100.86.157.64
